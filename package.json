{
    "name": "se-dictionary",
    "version": "1.0.0",
    "description": "Software Engineering Dictionary",
    "type": "module",
    "scripts": {
        "dev": "node server.js",
        "start": "node server.js",
        "vercel:dev": "vercel dev",
        "build:css": "sass public/styles/main.scss:public/styles/main.css --no-source-map",
        "watch:css": "sass public/styles/main.scss:public/styles/main.css --watch --no-source-map",
        "build": "npm run build:css && node build.js"
    },
    "dependencies": {
        "express": "^4.21.2",
        "mongodb": "^6.15.0"
    },
    "devDependencies": {
        "esbuild": "^0.27.4",
        "sass": "^1.98.0"
    }
}
